<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sunset Trails Photography</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
:root {
    --orange: #E67E22;
    --gold: #D4AF37;
    --beige: #F5E6D3;
    --black: #1C1C1C;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: var(--beige);
    color: var(--black);
    scroll-behavior: smooth;
}

h1, h2, h3 {
    font-family: 'Playfair Display', serif;
}

nav {
    position: fixed;
    width: 100%;
    padding: 20px 40px;
    display: flex;
    justify-content: space-between;
    background: rgba(28,28,28,0.6);
    backdrop-filter: blur(10px);
    z-index: 1000;
}

nav a {
    color: white;
    text-decoration: none;
    margin-left: 20px;
}

.hero {
    height: 100vh;
    background: url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
}

.hero h1 {
    font-size: 3rem;
    margin-bottom: 20px;
}

.btn {
    padding: 12px 25px;
    background: var(--gold);
    color: black;
    text-decoration: none;
    border-radius: 5px;
    transition: 0.3s;
}

.btn:hover {
    background: var(--orange);
}

.section {
    padding: 80px 10%;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.card {
    background: white;
    padding: 20px;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-10px);
}

.gallery img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    transition: 0.4s;
}

.gallery img:hover {
    transform: scale(1.05);
}

.testimonial {
    font-style: italic;
    margin-bottom: 20px;
}

.cta {
    background: var(--black);
    color: white;
    text-align: center;
    padding: 80px 20px;
}

form {
    display: grid;
    gap: 15px;
    max-width: 500px;
    margin: auto;
}

input, select, textarea {
    padding: 12px;
    border: none;
}

footer {
    text-align: center;
    padding: 20px;
    background: var(--black);
    color: white;
}

/* Mobile sticky CTA */
.mobile-cta {
    position: fixed;
    bottom: 0;
    width: 100%;
    background: var(--gold);
    text-align: center;
    padding: 15px;
    display: none;
}

@media(max-width:768px){
    .mobile-cta {
        display: block;
    }
}
</style>
</head>

<body>

<nav>
    <div>Sunset Trails</div>
    <div>
        <a href="#services">Services</a>
        <a href="#gallery">Gallery</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
    </div>
</nav>

<section class="hero">
    <div>
        <h1>Capturing Moments That Feel Like Forever</h1>
        <p>Luxury photography for life’s most meaningful moments</p>
        <br>
        <a href="#contact" class="btn">Book Your Session</a>
    </div>
</section>

<section class="section">
    <h2>Trusted by 100+ Happy Clients</h2>
    <p class="testimonial">“Absolutely breathtaking photos…”</p>
    <p class="testimonial">“Felt so natural and effortless…”</p>
</section>

<section id="services" class="section">
    <h2>Services</h2>
    <div class="grid">
        <div class="card">
            <h3>Weddings</h3>
            <p>Starting at $1,200+</p>
        </div>
        <div class="card">
            <h3>Engagements</h3>
            <p>Starting at $350+</p>
        </div>
        <div class="card">
            <h3>Family Sessions</h3>
            <p>Starting at $250+</p>
        </div>
        <div class="card">
            <h3>Maternity</h3>
            <p>Starting at $250+</p>
        </div>
        <div class="card">
            <h3>Branding</h3>
            <p>Starting at $400+</p>
        </div>
    </div>
</section>

<section id="gallery" class="section gallery">
    <h2>Gallery</h2>
    <div class="grid">
        <img src="https://images.unsplash.com/photo-1492724441997-5dc865305da7">
        <img src="https://images.unsplash.com/photo-1504203700686-0c4c8b3f9a43">
        <img src="https://images.unsplash.com/photo-1522673607200-164d1b6ce486">
        <img src="https://images.unsplash.com/photo-1495567720989-cebdbdd97913">
    </div>
</section>

<section id="about" class="section">
    <h2>About Me</h2>
    <p>
        I believe photography is more than just images — it’s about capturing emotions, 
        stories, and moments that last forever. My goal is to create a relaxed, 
        natural experience where you can truly be yourself.
    </p>
</section>

<section class="cta">
    <h2>Let’s Capture Your Story</h2>
    <br>
    <a href="#contact" class="btn">Check Availability</a>
</section>

<section id="contact" class="section">
    <h2>Book Your Session</h2>
    <p>Limited sessions available each month</p>
    <form>
        <input type="text" placeholder="Name" required>
        <input type="email" placeholder="Email" required>
        <select>
            <option>Type of Shoot</option>
            <option>Wedding</option>
            <option>Engagement</option>
            <option>Family</option>
            <option>Maternity</option>
        </select>
        <input type="date">
        <textarea placeholder="Message"></textarea>
        <button class="btn">Secure Your Session</button>
    </form>
</section>

<footer>
    <p>© 2026 Sunset Trails Photography</p>
</footer>

<div class="mobile-cta">
    <a href="#contact" style="text-decoration:none; color:black;">Book Now</a>
</div>

</body>
</html>
